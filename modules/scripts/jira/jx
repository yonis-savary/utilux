#!/bin/bash

jx_assert_is_configured()
{
    if [ -z "$UTILUX_JIRA_HOST" ] || [ -z "$UTILUX_JIRA_EMAIL" ] || [ -z "$UTILUX_JIRA_TOKEN" ]; then
        echo "Please configure your Jira connection first."
        echo "These variables must be configured :"
        echo " - UTILUX_JIRA_HOST"
        echo " - UTILUX_JIRA_EMAIL"
        echo " - UTILUX_JIRA_TOKEN"
        echo "You can configure them through the utilux-config command"
        echo ""
        exit 1
    fi
}





