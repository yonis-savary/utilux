jx_fetch()
{
    jx_assert_is_configured

    issue_key="$1"
    if [ -z "$issue_key" ]; then
        echo "Not enough arguments: this command needs an issue key"
        echo ""
        exit 1
    fi

    local auth="${UTILUX_JIRA_EMAIL}:${UTILUX_JIRA_TOKEN}"

    issue=$(curl -s \
        -u "$auth" \
        -H "Accept: application/json" \
        "${UTILUX_JIRA_HOST}/issue/${issue_key}")

    if echo "$issue" | grep -q '"errorMessages"'; then
        echo "$issue"
        exit 1
    fi

    issue_type=$(echo "$issue" | jq -r '.fields.issuetype.name // ""' 2>/dev/null)

    if [ "$issue_type" = "Epic" ]; then
        children=$(curl -s \
            -u "$auth" \
            -H "Accept: application/json" \
            "${UTILUX_JIRA_HOST}/search?jql=parent%3D${issue_key}&maxResults=100")

        jq -n \
            --argjson issue "$issue" \
            --argjson children "$children" \
            '{ issue: $issue, children: ($children.issues // []) }'
    else
        echo "$issue" | jq .
    fi

}

jx_fetch_help()
{
    echo "jx fetch - Fetch a Issue content from its issue-key"
    echo ""
    echo "Usage   : jx fetch <ISSUE-KEY>"
    echo "Example : jx fetch PRJCT-5002"
    echo ""
}




