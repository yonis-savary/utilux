jx_user_command="$1"

help()
{
    echo "jx - jira utils terminal"
    echo ""
    echo "Available subcommands"
    echo " - fetch <ISSUE-KEY>    Fetch an Issue and its content"
    echo
    echo "(Tip: you can use --help with any of these subcommands)"
}

if [ -z "$jx_user_command" ]; then
    echo "Please use a subcommand name after jx"
    help
    exit 1
fi

HELP_MODE="0"
for arg in "$@"; do
    if [ "$arg" = "--help" -o "$arg" = "-h" ]; then
        HELP_MODE="1"
    fi
done

case "$jx_user_command" in
    fetch)
        shift
        ([ "$HELP_MODE" = "1" ] && jx_fetch_help ) || jx_fetch "$@"
        ;;
    *)
        echo "Unrecognized subcommand $jx_user_command"
        help
        exit 1
        ;;
esac